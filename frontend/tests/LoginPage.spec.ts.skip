import { describe, it, expect, vi, beforeEach } from 'vitest'
import { mount } from '@vue/test-utils'
import { createPinia, setActivePinia } from 'pinia'
import { useUserStore } from '@/stores/user'

// Мок для Vuetify компонентов
vi.mock('vuetify', () => ({
  createVuetify: vi.fn(() => ({})),
}))

// Мок localStorage
beforeEach(() => {
  global.localStorage = {
    getItem: vi.fn(),
    setItem: vi.fn(),
    removeItem: vi.fn(),
    clear: vi.fn(),
    length: 0,
    key: vi.fn(),
  }
})

describe('LoginPage', () => {
  it('renders login form', async () => {
    setActivePinia(createPinia())
    // Импортируем компонент динамически, чтобы изолировать Vuetify
    const { default: LoginPage } = await import('@/pages/account/LoginPage.vue')
    const wrapper = mount(LoginPage, {
      global: {
        stubs: {
          VCard: true,
          VCardItem: true,
          VCardText: true,
          VTextField: true,
          VBtn: true,
          VAlert: true,
          VRow: true,
          VCol: true,
          VForm: true,
          RouterLink: true,
        },
      },
    })
    expect(wrapper.find('form').exists()).toBe(true)
  })

  it('calls store.login on submit', async () => {
    setActivePinia(createPinia())
    const store = useUserStore()
    const mockLogin = vi.fn().mockResolvedValue(undefined)
    store.login = mockLogin

    const { default: LoginPage } = await import('@/pages/account/LoginPage.vue')
    const wrapper = mount(LoginPage, {
      global: {
        stubs: {
          VCard: true,
          VCardItem: true,
          VCardText: true,
          VTextField: true,
          VBtn: true,
          VAlert: true,
          VRow: true,
          VCol: true,
          VForm: true,
          RouterLink: true,
        },
      },
    })
    
    await wrapper.find('input[type="text"]').setValue('testuser')
    await wrapper.find('input[type="password"]').setValue('pass')
    await wrapper.find('form').trigger('submit.prevent')

    expect(mockLogin).toHaveBeenCalledWith({ username: 'testuser', password: 'pass' })
  })
})
