import pytest
from app.models.user import User, UserRole
from app.models.project import Project, ProjectUserRole
from sqlalchemy import select

REG1 = {"email": "p1@example.com", "username": "p1user", "password": "password123"}
REG2 = {"email": "p2@example.com", "username": "p2user", "password": "password123"}


async def _auth(client, reg_data):
    r = await client.post("/api/users/register", json=reg_data)
    if r.status_code not in (200, 201):
        r = await client.post("/api/users/login",
                              json={"email": reg_data["email"], "password": reg_data["password"]})
    return r.json()["access_token"]


@pytest.mark.asyncio
async def test_project_lifecycle_and_members(client, db_session):
    # Register two users
    token1 = await _auth(client, REG1)
    token2 = await _auth(client, REG2)

    headers1 = {"Authorization": f"Bearer {token1}"}
    headers2 = {"Authorization": f"Bearer {token2}"}

    # Fetch user models from DB to have guide references
    u1_res = await db_session.execute(select(User).where(User.username == REG1["username"]))
    user1 = u1_res.scalar_one()

    u2_res = await db_session.execute(select(User).where(User.username == REG2["username"]))
    user2 = u2_res.scalar_one()

    # 1. Create a Project
    proj_payload = {"name": "Test Project Alpha", "description": "High importance description"}
    resp = await client.post("/api/projects", json=proj_payload, headers=headers1)
    assert resp.status_code == 201
    proj_data = resp.json()
    assert proj_data["name"] == "Test Project Alpha"
    assert proj_data["description"] == "High importance description"
    proj_guid = proj_data["guid"]

    # 2. Get Project Details
    get_resp = await client.get(f"/api/projects/{proj_guid}", headers=headers1)
    assert get_resp.status_code == 200
    assert get_resp.json()["name"] == "Test Project Alpha"

    # User 2 should not have access to read it initially -> Gets 404 or 403 (the dependency gets 404/403)
    get_fail_resp = await client.get(f"/api/projects/{proj_guid}", headers=headers2)
    assert get_fail_resp.status_code in [403, 404]

    # 3. Update Project Details
    up_resp = await client.put(f"/api/projects/{proj_guid}", json={"name": "Updated Name", "status": "active"}, headers=headers1)
    assert up_resp.status_code == 200
    assert up_resp.json()["name"] == "Updated Name"
    assert up_resp.json()["status"] == "active"

    # 4. List Projects with filters
    # First search matching 'Updated'
    list_resp = await client.get("/api/projects?search=Updated", headers=headers1)
    assert list_resp.status_code == 200
    assert len(list_resp.json()) == 1

    # Search with status filter
    list_active_resp = await client.get("/api/projects?status=active", headers=headers1)
    assert list_active_resp.status_code == 200
    assert len(list_active_resp.json()) == 1

    # Search without matches
    list_empty_resp = await client.get("/api/projects?search=NonExistentQuery", headers=headers1)
    assert list_empty_resp.status_code == 200
    assert len(list_empty_resp.json()) == 0

    # 5. Membership Management
    # List members (should contain user1 as owner)
    members_resp = await client.get(f"/api/projects/{proj_guid}/users", headers=headers1)
    assert members_resp.status_code == 200
    members = members_resp.json()
    assert len(members) == 1
    assert members[0]["user_guid"] == user1.guid

    # Add user2 to project as a "member"
    add_member_resp = await client.post(
        f"/api/projects/{proj_guid}/users",
        json={"user_guid": user2.guid, "role": "member"},
        headers=headers1
    )
    assert add_member_resp.status_code == 201
    assert add_member_resp.json()["user_guid"] == user2.guid

    # User 2 can now access the project
    get_ok_resp2 = await client.get(f"/api/projects/{proj_guid}", headers=headers2)
    assert get_ok_resp2.status_code == 200

    # Update Member role
    up_member_resp = await client.put(
        f"/api/projects/{proj_guid}/users/{user2.guid}",
        json={"role": "editor"},
        headers=headers1
    )
    assert up_member_resp.status_code == 200
    assert up_member_resp.json()["role"] == "editor"

    # Try updating non-existent member
    up_fake_member = await client.put(
        f"/api/projects/{proj_guid}/users/00000000-0000-0000-0000-000000000000",
        json={"role": "editor"},
        headers=headers1
    )
    assert up_fake_member.status_code == 404

    # 6. Service Ends: Project Statistics & PDF Export
    # Project stats
    stats_resp = await client.get(f"/api/projects/{proj_guid}/stats", headers=headers1)
    assert stats_resp.status_code == 200
    assert "readiness_score" in stats_resp.json()

    # Export PDF (Must return application/pdf and dynamic filename headers)
    pdf_resp = await client.get(f"/api/projects/{proj_guid}/export/pdf", headers=headers1)
    assert pdf_resp.status_code == 200
    assert pdf_resp.headers["content-type"] == "application/pdf"

    # 7. Member Deletion & Project Deletion
    # Remove User 2 member
    del_member_resp = await client.delete(f"/api/projects/{proj_guid}/users/{user2.guid}", headers=headers1)
    assert del_member_resp.status_code == 204

    # Try removing non-member
    del_fake_member = await client.delete(f"/api/projects/{proj_guid}/users/{user2.guid}", headers=headers1)
    assert del_fake_member.status_code == 404

    # User 2 tries to delete project -> Forbidden (403)
    del_proj_fail = await client.delete(f"/api/projects/{proj_guid}", headers=headers2)
    assert del_proj_fail.status_code == 403

    # Owner deletes project -> Success (204)
    del_proj_ok = await client.delete(f"/api/projects/{proj_guid}", headers=headers1)
    assert del_proj_ok.status_code == 204
